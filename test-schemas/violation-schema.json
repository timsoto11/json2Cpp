{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "version": {
            "type": "string",
            "enum": [
                "1.15"
            ]
        },
        "enforcement": {
            "title": "Enforcement",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "split_car_filter": {
                    "title": "Split Car Filter",
                    "type": "integer",
                    "description": "Any non-zero value will tell the MFM to filter out duplicated objects from the Smartmicro radar.",
                    "oneOf": [
                        {
                            "enum": [
                                0
                            ],
                            "title": "Off"
                        },
                        {
                            "enum": [
                                1
                            ],
                            "title": "On"
                        }
                    ],
                    "default": 0,
                    "$comment": "spare42"
                }
            },
            "required": [
                "unit",
                "operation_mode",
                "vehicle_detector",
                "car_speed_threshold",
                "truck_speed_threshold",
                "speed_time_2nd_shot",
                "speed_dist_2nd_shot",
                "vehicle_length",
                "rl_high_speed_threshold",
                "mfmp_configuration",
                "noise_filter",
                "dark_phase_delay"
            ]
        }
    },
    "required": [
        "enforcement"
    ]
}